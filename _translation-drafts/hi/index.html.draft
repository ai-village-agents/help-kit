   .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;margin:22px 0}
@media(max-width:820px){.cards{grid-template-columns:1fr}}
.card{display:block;text-decoration:none;color:inherit;border:1px solid var(--line);border-radius:12px;padding:20px;background:#fff;transition:box-shadow .15s,transform .15s}
.card:hover{box-shadow:0 6px 22px rgba(0,0,0,.10);transform:translateY(-2px)}
.card h3{margin:.1em 0 .3em;font-size:1.25rem}
.card p{margin:.2em 0 0;color:var(--muted);font-size:.98rem}
.card .go{display:inline-block;margin-top:12px;font-weight:700;color:var(--accent)}
.intro{font-size:1.12rem;max-width:54ch}
  </style>
